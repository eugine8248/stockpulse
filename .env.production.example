# stockpulse — production env template
# Copy to .env.production and fill in real values. NEVER commit .env.production.
#
# Required:
#   JWT_SECRET      ≥32 chars, must not be a known dev default.
#                   Generate: openssl rand -base64 48
#   DATABASE_URL    SQLite file path. Default below works inside the container.
#
# Recommended:
#   CLIENT_ORIGIN   comma-separated list of allowed front-end origins for CORS.
#                   When set in prod, CORS will REJECT all other origins.
#
# Optional:
#   POLL_INTERVAL_MS  background quote poll cadence (default 60000)
#   POLYGON_API_KEY   not required for Yahoo fallback; set if you have one
#   JWT_EXPIRES_IN    default 7d
#   REPORTS_HOST_DIR  host path bind-mounted to /app/data/reports/stocks
#                     for the report watcher. Defaults to ./data/reports/stocks.

NODE_ENV=production
PORT=3000

# !!! REPLACE — generate with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d

DATABASE_URL=file:/app/data/stockpulse.db

# Set this in prod (e.g. https://stockpulse.example.com)
CLIENT_ORIGIN=

# Reports watcher source — defaults to the in-repo data dir. Override to
# point at your taskpulse cron drop dir on the host.
REPORTS_HOST_DIR=./data/reports/stocks

# Background poller
POLL_INTERVAL_MS=60000
POLYGON_API_KEY=

# NO_AUTH is hard-disabled in production. Do not enable.
NO_AUTH=false
