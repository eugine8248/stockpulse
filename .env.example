# Copy to .env and fill in. None of these are required to run locally —
# defaults are sane for a single-user localhost setup.

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Set to 'true' to disable login entirely (single-user local mode).
# All requests will be served as the auto-created user id=1.
NO_AUTH=false

# How often (ms) the backend polls Yahoo Finance for watchlist tickers.
# Lower = more real-time, higher = lighter on Yahoo's servers.
POLL_INTERVAL_MS=5000

# Optional Polygon.io API key. If set, Settings page will offer Polygon as
# an alternative data source. Leave blank to use Yahoo (free, no key) only.
POLYGON_API_KEY=

# Server port
PORT=3000

# SQLite file location (bind-mounted in Docker)
DATABASE_URL=file:./data/stockpulse.db
